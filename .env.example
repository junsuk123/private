# Keep live trading disabled unless a later phase explicitly implements approval flows.
APP_ENV=local
DATA_ENV=live
TRADING_MODE=read_only
LIVE_TRADING_ENABLED=false

# Future integrations should load secrets from environment variables or a secret manager.
OPENDART_API_KEY=
FRED_API_KEY=
BROKER_API_KEY=
BROKER_API_SECRET=

# Korea Investment & Securities Open API (KIS Developers).
# Paper mode uses https://openapivts.koreainvestment.com:29443 and live mode uses
# https://openapi.koreainvestment.com:9443. Keep KIS_LIVE_ENABLED=false until
# manual approval and risk gates are intentionally enabled.
KIS_LIVE_ENABLED=false
KIS_PAPER_TRADING=true
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CODE=01
KIS_TIMEOUT_SECONDS=10

# Optional LLM event/news classifier. If disabled or unavailable, keyword fallback is used.
LLM_EVENT_CLASSIFIER_ENABLED=false
LLM_EVENT_PROVIDER=local
LLM_EVENT_MODEL=qwen2.5:1.5b-instruct
LLM_EVENT_API_KEY=
LLM_EVENT_LOCAL_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
LLM_EVENT_ENDPOINT=https://api.openai.com/v1/chat/completions

# In-process local model mode, no local server required:
# LLM_EVENT_PROVIDER=embedded
# LLM_EVENT_MODEL=models/local-llm/event-classifier
# LLM_EVENT_DEVICE=auto
# LLM_EVENT_MODEL_CACHE_DIR=models/local-llm/cache
# LLM_EVENT_LOCAL_FILES_ONLY=true
# LLM_EVENT_MAX_NEW_TOKENS=512

# Multimodal in-process mode for Hugging Face vision-language checkpoints:
# LLM_EVENT_PROVIDER=multimodal
# LLM_EVENT_MODEL=google/diffusiongemma-26B-A4B-it
# LLM_EVENT_DEVICE=auto
# LLM_EVENT_MODEL_CACHE_DIR=models/local-llm/cache
# LLM_EVENT_LOCAL_FILES_ONLY=true
# LLM_EVENT_MAX_NEW_TOKENS=512

# OpenVINO/NPU in-process mode, when optimum-intel/openvino supports the model:
# LLM_EVENT_PROVIDER=openvino-llm
# LLM_EVENT_DEVICE=NPU
# LLM_EVENT_INFERENCE_BACKEND=openvino

# Low-latency inference preference. CPU fallback remains enabled.
ONTOLOGY_ACCELERATOR=NPU
REALTIME_LATENCY_PROFILE=low_latency
OPENVINO_DEVICE=NPU
OPENVINO_HINT_PERFORMANCE_MODE=LATENCY
OPENVINO_ENABLE_CPU_PINNING=YES
