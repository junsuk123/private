def _ensure_background_refresh() -> None:
  global _refresh_worker
  with _live_lock:
    if bool(_live_state["is_refreshing"]):
      _live_state["refresh_requested_after_current"] = True
      return
    if _refresh_worker is not None and _refresh_worker.is_alive():
