# Korea Investment & Securities Open API credentials.
# Copy this file to config/secrets/kis_api_keys.env and fill local values there.

# Keep disabled until manual approval and risk gates are intentionally enabled.
KIS_LIVE_ENABLED=false
KIS_PAPER_TRADING=true

# Paper trading / virtual account credentials.
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CODE=01

# Live account credentials.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

KIS_TIMEOUT_SECONDS=10
