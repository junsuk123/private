# Korea Investment & Securities Open API credentials.
# Copy this file to config/secrets/kis_api_keys.env and fill local values there.

# Keep disabled until manual approval and risk gates are intentionally enabled.
LIVE_TRADING_ENABLED=false
KIS_LIVE_ENABLED=false
KIS_PAPER_TRADING=true
LIVE_ORDER_SUBMIT_ENABLED=false
REQUIRE_MANUAL_ARMING=true
KILL_SWITCH_ENABLED=true

# Paper trading / virtual account credentials.
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CODE=01
KIS_PAPER_HTS_ID=
KIS_PAPER_CUSTTYPE=P

# Live account credentials.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=
KIS_CUSTTYPE=P
KIS_BASE_URL_REAL=https://openapi.koreainvestment.com:9443
KIS_BASE_URL_PAPER=https://openapivts.koreainvestment.com:29443
# Optional: paste an already-issued live access token to reuse it without
# calling /oauth2/tokenP again. Leave expiry blank if unknown.
KIS_LIVE_ACCESS_TOKEN=
KIS_LIVE_ACCESS_TOKEN_EXPIRES_AT=

KIS_TIMEOUT_SECONDS=10
